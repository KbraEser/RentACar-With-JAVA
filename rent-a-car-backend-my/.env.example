# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası repoya commit edilmez.

DB_URL=jdbc:postgresql://localhost:5432/rentacar
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# En az 256 bit rastgele anahtar: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# Access token: 15 dk (900000 ms) | Refresh token: 7 gün (604800000 ms)
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Geliştirme: dev | Üretim: prod
SPRING_PROFILES_ACTIVE=dev

# Redis (login rate limiting — varsayılan: localhost:6379)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=true

# Login brute-force koruması
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
